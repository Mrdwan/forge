# Forge — Environment Variables
#
# Copy this to .env and fill in your values. Never commit .env.
# Every FORGE_* variable is optional — values in config.yaml are used as fallback.

# ─── Telegram ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── API Keys ────────────────────────────────────────────────────────────────
# Set keys for whichever providers you use. Unused keys can be left blank.
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
# OPENROUTER_API_KEY=    # Route all models through one provider

# ─── Project Path ─────────────────────────────────────────────────────────────
# Override the project.path and project.memory_dir from config.yaml
# FORGE_PROJECT_PATH=/home/you/my-project
# FORGE_MEMORY_DIR=memory

# ─── Models (litellm format: "provider/model-name") ───────────────────────────
# Override any model without editing config.yaml.
# See https://docs.litellm.ai/docs/providers for all supported providers.
#
# FORGE_MODEL_CODER=anthropic/claude-sonnet-4-5
# FORGE_MODEL_CODER_FALLBACK=gemini/gemini-2.5-pro
# FORGE_MODEL_JUNIOR_REVIEWER=deepseek/deepseek-chat
# FORGE_MODEL_SENIOR_REVIEWER=anthropic/claude-sonnet-4-5
# FORGE_MODEL_CONTEXT_UPDATER=deepseek/deepseek-chat

# ─── Pipeline Limits ──────────────────────────────────────────────────────────
# FORGE_MAX_HOOK_RETRIES=3
# FORGE_MAX_JUNIOR_RETRIES=3
# FORGE_MAX_SENIOR_ROUNDS=2
# FORGE_AIDER_TIMEOUT=900

# ─── Pre-commit Commands ──────────────────────────────────────────────────────
# Comma-separated list. e.g. to skip mypy:
# FORGE_PRECOMMIT_COMMANDS=ruff check src/,pytest tests/ -x -q --tb=short

# ─── Roadmap Patterns ─────────────────────────────────────────────────────────
# FORGE_UNCHECKED_PATTERN=^\s*-\s*\[ \]\s*\*{0,2}Step\s+(\d+\.\d+):?\*{0,2}\s*(.*)
# FORGE_CHECKED_PATTERN=^\s*-\s*\[x\]\s*\*{0,2}Step\s+(\d+\.\d+):?\*{0,2}\s*(.*)
